# ========================================
# RestoCost Environment Configuration
# ========================================
# Copy this file to .env and update values for your environment
# DO NOT commit .env to Git!

# ========================================
# Docker Services Ports
# ========================================
POSTGRES_PORT=5432
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_USER=restocost
POSTGRES_PASSWORD=restocost
POSTGRES_DB=restocost

# For backend app (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://restocost:restocost@postgres:5432/restocost

# For local development (outside Docker)
# DATABASE_URL=postgresql+asyncpg://restocost:restocost@localhost:5432/restocost

# SQLite for local testing (optional)
# DATABASE_URL=sqlite+aiosqlite:///./restocost.db

# ========================================
# Security & Authentication
# ========================================
# IMPORTANT: Generate a secure secret key for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme-generate-a-secure-random-key-here

# JWT Algorithm (DO NOT CHANGE unless you know what you're doing)
ALGORITHM=HS256

# ========================================
# API Configuration
# ========================================
API_V1_PREFIX=/api
PROJECT_NAME=RestoCost
VERSION=0.1.0

# ========================================
# Environment
# ========================================
# Options: development, staging, production
ENVIRONMENT=development

# Enable debug mode (should be False in production)
DEBUG=True

# ========================================
# CORS Configuration
# ========================================
# Comma-separated list of allowed origins
# Development default
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000

# Production example
# ALLOWED_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
