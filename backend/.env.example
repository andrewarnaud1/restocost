# ========================================
# RestoCost Backend Configuration
# ========================================
# Copy this file to .env and update values
# DO NOT commit .env to Git!

# ========================================
# Database Configuration
# ========================================
# PostgreSQL (Production)
DATABASE_URL=postgresql+asyncpg://restocost:restocost@localhost:5432/restocost

# SQLite (Development - for local testing)
# DATABASE_URL=sqlite+aiosqlite:///./restocost.db

# ========================================
# Security
# ========================================
# IMPORTANT: Generate a secure secret key for production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changeme-generate-a-secure-random-key-here

# JWT Algorithm (DO NOT CHANGE unless you know what you're doing)
ALGORITHM=HS256

# ========================================
# API Configuration
# ========================================
# API prefix (e.g., /api, /v1, etc.)
API_V1_PREFIX=/api

# Project metadata
PROJECT_NAME=RestoCost
VERSION=0.1.0

# ========================================
# Environment
# ========================================
# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (should be False in production)
DEBUG=True

# ========================================
# CORS Configuration
# ========================================
# Allowed origins (comma-separated for multiple)
# Development default: http://localhost:3000,http://localhost:5173
# Production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# User Management
# ========================================
# Note: Public registration is ALWAYS disabled.
# Users must be created by administrators via /api/admin/users
# The first admin is created via: python create_admin.py
